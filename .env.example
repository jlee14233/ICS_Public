# .env.example
# ==========================================
# 포트폴리오를 위한 환경 변수 템플릿입니다.
# 실제 운영 환경에서는 아래 값들을 알맞게 채워 사용하세요.
# 보안 유지를 위해 실제 .env 파일은 Git에 포함되지 않습니다.
# ==========================================

# 1. 시스템 기본 경로
DESKTOP_PATH=C:\Users\username\Desktop
GLIDER_BIN_PATH=C:\path\to\WINDOZE-PREBUILT-BINARIES

# 2. Discord 연동
DISCORD_TOKEN_FLOAT=bot_token_here
DISCORD_TOKEN_OPERATION=app_token_here
CHANNEL_ID_FLOAT_ALARM=123456789
CHANNEL_ID_LOGS=123456789
CHANNEL_ID_IMAGES=123456789
CHANNEL_ID_WAKE_TIME=123456789

# 3. 데이터 동기화 (NAS & SSH)
NAS_ENABLED=True
NAS_TARGET_SERVER=195
NAS_BASE_PATH=Z:\Glider_Archive
SSH_PRIVATE_KEY_PATH=C:\keys\private_key.pem
DATA_SERVER_HOST=192.168.0.100
DATA_SERVER_PORT=22
DATA_SERVER_USER=admin
DATA_SERVER_PASSWORD=secret
DATA_SERVER_DOCK_PATH=/remote/dock/path/

# 4. 웹 서버 (FastAPI & RPC)
WS_URI=ws://localhost:8000/ws
FRONTEND_URL=http://localhost:3000
SECRET_KEY=my-super-secret-key
ACTIVE_GLIDERS=glider_A,glider_B,glider_C

# 5. 서드파티 API
WEATHER_API_KEY=your_weather_api_key_here
